rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin(); // Only admins can promote users to admin
    }

    // Lead history
    match /leads/{leadId} {
      allow read, write: if isAuthenticated();
      // In a stricter app, users might only see their own leads
    }

    // Knowledge Base (Circulars)
    match /knowledge_base/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only admins can ingest new circulars
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
